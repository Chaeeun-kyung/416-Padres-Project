  "item": [
    {
      "name": "State Summary",
      "item": [
        {
          "name": "Get State Summary - AZ (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Summary response has current dashboard fields', function () {",
                  "    pm.expect(body.stateCode).to.eql('AZ');",
                  "    pm.expect(body).to.have.property('districts');",
                  "    pm.expect(body).to.have.property('votingAgePopulation');",
                  "    pm.expect(body).to.have.property('racialEthnicPopulationPct');",
                  "    pm.expect(body).to.have.property('racialEthnicPopulationMillions');",
                  "    pm.expect(body).to.have.property('voterDistribution');",
                  "    pm.expect(body).to.have.property('ensembleSummary');",
                  "    pm.expect(body).to.have.property('redistrictingControl');",
                  "    pm.expect(body).to.have.property('congressionalPartySummary');",
                  "});",
                  "",
                  "pm.test('Summary values are realistic', function () {",
                  "    pm.expect(body.districts).to.be.a('number');",
                  "    pm.expect(body.districts).to.be.above(0);",
                  "    pm.expect(body.votingAgePopulation).to.be.a('number');",
                  "    pm.expect(body.voterDistribution.demVotes).to.be.a('number');",
                  "    pm.expect(body.voterDistribution.repVotes).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/states/AZ/summary"
          },
          "response": []
        },
